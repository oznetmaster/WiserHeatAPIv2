<Window x:Class="WiserHeatApp.Wpf.Views.ShellWindow"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Title="Wiser for Windows" Height="720" Width="1280" WindowStartupLocation="Manual">
 <DockPanel>
 <!-- Top bar -->
 <Grid DockPanel.Dock="Top" Height="56" Background="#FF1F1F1F">
 <Grid.ColumnDefinitions>
 <ColumnDefinition Width="Auto"/>
 <ColumnDefinition Width="*"/>
 <ColumnDefinition Width="Auto"/>
 </Grid.ColumnDefinitions>
 <TextBlock Text="Wiser" Foreground="White" FontSize="20" VerticalAlignment="Center" Margin="16,0"/>
 <TextBox x:Name="SearchBox" Grid.Column="1" Margin="16" Height="32" VerticalAlignment="Center"/>
 <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
 <Button Content="Home" Margin="6,0" x:Name="HomeBtn"/>
 <Button Content="Rooms" Margin="6,0" x:Name="RoomsBtn"/>
 <Button Content="Schedules" Margin="6,0" x:Name="SchedulesBtn"/>
 <Button Content="Settings" Margin="6,0" x:Name="SettingsBtn"/>
 </StackPanel>
 </Grid>

 <!-- Main content placeholder -->
 <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden" />
 </DockPanel>
</Window>