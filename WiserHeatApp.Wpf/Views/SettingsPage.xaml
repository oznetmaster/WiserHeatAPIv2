<Page x:Class="WiserHeatApp.Wpf.Views.SettingsPage"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 mc:Ignorable="d"
 Title="Settings">
 <Grid Margin="16">
 <Grid.RowDefinitions>
 <RowDefinition Height="Auto"/>
 <RowDefinition Height="*"/>
 </Grid.RowDefinitions>
 <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
 <StackPanel>
 <TextBlock Text="Hub IP"/>
 <TextBox x:Name="IpBox" Width="220" Height="28"/>
 </StackPanel>
 <StackPanel Margin="12,0,0,0">
 <TextBlock Text="Secret"/>
 <PasswordBox x:Name="SecretBox" Width="220" Height="28"/>
 </StackPanel>
 <StackPanel Margin="12,0,0,0">
 <TextBlock Text="Auto refresh (sec)"/>
 <TextBox x:Name="RefreshIntervalBox" Width="120" Height="28"/>
 </StackPanel>
 <StackPanel Orientation="Horizontal" Margin="12,18,0,0">
 <Button x:Name="DiscoverBtn" Content="Discover" Width="100" Height="28" Margin="0,0,8,0"/>
 <Button x:Name="ConnectBtn" Content="Connect" Width="100" Height="28"/>
 </StackPanel>
 </StackPanel>
 <ListView Grid.Row="1" x:Name="HubsList" Margin="0,12,0,0" DisplayMemberPath="Url"/>
 </Grid>
</Page>