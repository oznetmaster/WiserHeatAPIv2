{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "WiserHeatAPIv2/WiserHeatAPIv2.csproj"
          ],
          "src": ".."
        }
      ],
      "dest": "api",
      "disableGitFeatures": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml"
        ]
      },
      {
        "files": [
          "articles/**.md"
        ]
      },
      {
        "files": [
          "index.md"
        ]
      },
      {
        "files": [
          "toc.yml"
        ]
      }
    ],
    "globalMetadata": {
      "_appTitle": "WiserHeatAPIv2 API"
    },
    "template": [
      "default",
      "modern"
    ],
    "dest": "_site"
  },
  "pdf": {
    "content": [
      {
        "files": [
          "api/**.yml"
        ]
      }
    ],
    "dest": "pdf",
    "wkhtmltopdf": {
      "path": "C:/Program Files/wkhtmltopdf/bin/wkhtmltopdf.exe",
      "additionalArguments": "--enable-local-file-access"
    }
  }
}